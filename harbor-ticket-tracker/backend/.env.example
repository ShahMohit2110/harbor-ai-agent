# Azure DevOps Configuration
# Copy this file to .env and fill in your values

# Azure DevOps Personal Access Token
# Generate at: https://dev.azure.com/{organization}/_usersSettings/tokens
# Required permissions: Read & Write for Work Items
AZURE_DEVOPS_PAT=your_pat_here

# Azure DevOps Organization
# Example: myorganization or dev.azure.com/myorganization
AZURE_DEVOPS_ORG=your_organization

# Azure DevOps Project
# The project name where your work items are located
AZURE_DEVOPS_PROJECT=your_project_name

# Harbor Service Configuration
# Base path to all Harbor service repositories
HARBOR_REPOS_PATH=/Users/mohitshah/Documents/HarborService

# Service Mapping (Azure DevOps Area Path → Repository Name)
# Format: area_path:repo_name (one per line)
# This tells the tracker which repo to monitor for each ticket
SERVICE_MAPPING=harborJobSvc:harborJobSvc
SERVICE_MAPPING_2=harborUserSvc:harborUserSvc
SERVICE_MAPPING_3=harborWebsite:harborWebsite
